#inheritance program
class person:
    def __init__(self,name,age):
        self.name=name
        self.age=age
    def display(self):
        print("student name is=",self.name)
        print("student age=",self.age)
class student(person):
    def __init__(self,name,age ,mark):
        person.__init__(self,name,age)
    def stud(self):
        print("I am student")
        
stud1=student("pratik",20,90)
stud1.stud()
stud1.display()
